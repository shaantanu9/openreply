# =============================================================================
# Activation Suite — env template
# Copy to .env (gitignored) and fill values. In Vercel, paste these into
# Project Settings → Environment Variables.
# =============================================================================

# -----------------------------------------------------------------------------
# Public — browser-visible (Next.js inlines NEXT_PUBLIC_* at build time)
# -----------------------------------------------------------------------------

# Supabase project (anon key is safe to ship to the browser; RLS enforces auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Set ONLY if the licence/activation API is on a different host than the
# marketing site. Leave blank for same-origin (recommended in Vercel).
NEXT_PUBLIC_LICENSE_API_BASE=

# Marketing + activate page integrations
# Download CTAs default to /api/download, which redirects to the LATEST
# GitHub release asset for the visitor's OS. Leave this BLANK to keep that
# behaviour. Set it only to force every download link at one fixed URL
# (e.g. a CDN-hosted build) — doing so disables the per-platform logic.
NEXT_PUBLIC_APP_DOWNLOAD_URL=
# Optional. A GitHub token (classic, no scopes needed for public repos, or
# fine-grained read-only on Contents) raises the Releases API rate limit from
# 60 to 5,000 req/hour. Not required — responses are cached 15 min — but
# recommended for high-traffic production. Server-only; never NEXT_PUBLIC.
GITHUB_TOKEN=
NEXT_PUBLIC_APP_DEEP_LINK_URL=gapmap://dashboard

# Lemon Squeezy hosted-checkout URLs (deferred until store exists)
NEXT_PUBLIC_LEMONSQUEEZY_CHECKOUT_PRO=
NEXT_PUBLIC_LEMONSQUEEZY_CHECKOUT_LIVE_PASS=
NEXT_PUBLIC_LEMONSQUEEZY_CUSTOMER_PORTAL=

# -----------------------------------------------------------------------------
# Server-only — Supabase
# -----------------------------------------------------------------------------

# Usually identical to NEXT_PUBLIC_SUPABASE_URL. Both names are read.
SUPABASE_URL=https://your-project-id.supabase.co

# Required for privileged DB writes (licence issuance, device activation,
# webhook handlers). NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional — only needed if a server route does anon-role reads. Defaults
# to NEXT_PUBLIC_SUPABASE_ANON_KEY when unset.
# SUPABASE_ANON_KEY=your_supabase_anon_key

# -----------------------------------------------------------------------------
# JWT signing — server-only
# -----------------------------------------------------------------------------

# Signs the activation token returned to the desktop binary. MUST be
# >= 32 chars AND exactly match the desktop's JWT_DESKTOP_SECRET (baked at
# `cargo build` time via app-tauri/src-tauri/build.rs). A mismatch causes
# every activation to fail with `invalid-signature` on the desktop.
TOKEN_SIGNING_SECRET=replace_with_a_long_random_at_least_32_chars

# -----------------------------------------------------------------------------
# Dev-only — local key minting
# -----------------------------------------------------------------------------

# Shared secret required by /api/v1/dev/mint to issue test licences.
DEV_MINT_SECRET=replace_with_long_random_secret

# Hard gate for /api/v1/dev/mint. Must be literally "true" to enable;
# any other value (incl. unset) returns 403. Keep "false" in production —
# NODE_ENV alone is not a reliable gate on serverless runtimes.
ALLOW_DEV_MINT=false

# -----------------------------------------------------------------------------
# Trial / plan tuning
# -----------------------------------------------------------------------------

# Length of the free trial granted by /api/v1/trial/start. Defaults to 14.
TRIAL_DAYS=14

# -----------------------------------------------------------------------------
# Lemon Squeezy — server-only (deferred until store is live)
# -----------------------------------------------------------------------------

# REST API key — used to look up customer/order details after a webhook.
# LS_API_KEY=

# HMAC-SHA256 secret that signs every webhook from Lemon Squeezy. Required
# for /api/v1/webhooks/lemonsqueezy to accept any request.
# LS_WEBHOOK_SECRET=

# JSON map: { "<variantId>": { "plan": "pro" | "team" | "live_pass",
#   "livePass": boolean, "isTrial": boolean, "trialDays": number,
#   "maxDevices": number } }
# Lets one webhook handler resolve any LS variant to the right plan. When
# unset, every purchase falls back to a single-device "pro" plan.
# LS_VARIANT_MAP={"123456":{"plan":"pro","livePass":false,"isTrial":false,"trialDays":0,"maxDevices":1}}

# -----------------------------------------------------------------------------
# Transactional email — for licence-key delivery (optional)
# -----------------------------------------------------------------------------

# RESEND_API_KEY=
