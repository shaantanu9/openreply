# See https://help.github.com/articles/ignoring-files/

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.npm-cache/

# ── Next.js ──────────────────────────────────────────────────────────────────
/.next/
/out/
next-env.d.ts

# ── Build artifacts ──────────────────────────────────────────────────────────
/build
/dist
*.tsbuildinfo

# ── Local data / cache (never deploy) ────────────────────────────────────────
/data

# ── Testing ──────────────────────────────────────────────────────────────────
/coverage

# ── Logs ─────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ── Env files (NEVER commit secrets) ─────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
# Keep the example template tracked
!.env.example

# ── Vercel ───────────────────────────────────────────────────────────────────
.vercel

# ── Supabase local state ─────────────────────────────────────────────────────
supabase/.branches
supabase/.temp
supabase/.env

# ── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
*.pem
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
.admin-creds.local.md
.admin-secret.txt
