# Gap Map static site / tooling — copy to .env and fill in (root .gitignore ignores .env)
#
# Public browser config generated into env.config.js:
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
LICENSE_API_BASE=https://your-api.example.com

# Optional direct app download URL used by "Download for Mac" buttons.
# If empty, CTAs route users to sign-in/activate flow pages.
# APP_DOWNLOAD_URL=https://your-domain.com/download/gapmap-latest.dmg
# Optional desktop deep-link URL used by "Open desktop app" after activation.
# APP_DEEP_LINK_URL=gapmap://dashboard

# Lemon Squeezy hosted links (public):
LEMONSQUEEZY_CHECKOUT_PRO=
LEMONSQUEEZY_CHECKOUT_LIVE_PASS=
LEMONSQUEEZY_CUSTOMER_PORTAL=

# Server-only secrets (never copied to env.config.js):
# SUPABASE_SERVICE_ROLE_KEY=
# DEV_MINT_SECRET=
# LEMONSQUEEZY_WEBHOOK_SECRET=
# LEMONSQUEEZY_API_KEY=
