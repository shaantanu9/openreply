{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Gap Map main window — core defaults + scoped dialog + sidecar execution only",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/reddit-cli", "sidecar": true, "args": true }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "binaries/reddit-cli", "sidecar": true, "args": true }
      ]
    }
  ]
}
