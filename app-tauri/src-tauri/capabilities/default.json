{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Gap Map main + splash windows — core defaults, explicit event listen/emit (chat/collect/enrich streams rely on plugin:event|listen), scoped dialog + sidecar execution only",
  "windows": ["main", "splash"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:event:allow-emit-to",
    "core:event:allow-unlisten",
    "dialog:allow-open",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/gapmap", "sidecar": true, "args": true }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "binaries/gapmap", "sidecar": true, "args": true }
      ]
    }
  ]
}
