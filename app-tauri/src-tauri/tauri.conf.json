{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gap Map",
  "version": "0.1.0",
  "identifier": "com.shantanu.gapmap",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Gap Map",
        "width": 1380,
        "height": 880,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      },
      {
        "label": "splash",
        "url": "splash.html",
        "width": 360,
        "height": 240,
        "center": true,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self' 'unsafe-inline' https://d3js.org https://cdnjs.cloudflare.com",
        "style-src": "'self' 'unsafe-inline' https://fonts.googleapis.com",
        "font-src": "'self' https://fonts.gstatic.com",
        "img-src": "'self' asset: http://asset.localhost data: blob:",
        "connect-src": "ipc: http://ipc.localhost asset: http://asset.localhost http://localhost:* https://www.reddit.com https://api.reddit.com https://oauth.reddit.com https://eutils.ncbi.nlm.nih.gov https://api.openalex.org https://api.semanticscholar.org https://export.arxiv.org https://arxiv.org https://hn.algolia.com https://api.github.com https://dev.to https://api.stackexchange.com https://newsapi.org https://trends.google.com https://itunes.apple.com https://play.google.com https://api.anthropic.com https://api.openai.com https://openrouter.ai https://api.groq.com https://api.deepseek.com https://api.mistral.ai https://generativelanguage.googleapis.com https://chroma-onnx-models.s3.amazonaws.com https://api.pullpush.io https://gapmap.myind.ai",
        "frame-src": "'self' asset: http://asset.localhost",
        "object-src": "'none'",
        "base-uri": "'self'",
        "frame-ancestors": "'none'"
      },
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$APPDATA/**",
            "$APPDATA/gapmap/**",
            "$APPLOCALDATA/**",
            "$APPLOCALDATA/paper_pdf_cache/**",
            "$HOME/Library/Application Support/com.shantanu.gapmap/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "copyright": "© 2026 Shantanu Bombatkar",
    "shortDescription": "Multi-source research gap finder",
    "longDescription": "Gap Map discovers product gaps by fusing Reddit, HN, arXiv, GitHub, and 6 more sources into a single searchable corpus, then extracts pain-points and workarounds via LLM.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/gapmap-cli",
      "binaries/ffmpeg"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "./Entitlements.plist",
      "exceptionDomain": "",
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 200
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 200
        }
      }
    },
    "fileAssociations": []
  },
  "plugins": {}
}
