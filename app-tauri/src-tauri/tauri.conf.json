{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gap Map",
  "version": "0.1.0",
  "identifier": "com.shantanu.gapmap",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Gap Map",
        "width": 1380,
        "height": 880,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      },
      {
        "label": "splash",
        "url": "splash.html",
        "width": 360,
        "height": 240,
        "center": true,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline' https://fonts.googleapis.com",
        "font-src": "'self' https://fonts.gstatic.com",
        "img-src": "'self' asset: http://asset.localhost data: blob:",
        "connect-src": "ipc: http://ipc.localhost asset: http://asset.localhost http://localhost:* https://*",
        "frame-src": "'self' asset: http://asset.localhost",
        "object-src": "'none'",
        "base-uri": "'self'",
        "frame-ancestors": "'none'"
      },
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$APPDATA/**",
            "$APPDATA/reddit-myind/**",
            "$HOME/Library/Application Support/com.shantanu.gapmap/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "copyright": "© 2026 Shantanu Bombatkar",
    "shortDescription": "Multi-source research gap finder",
    "longDescription": "Gap Map discovers product gaps by fusing Reddit, HN, arXiv, GitHub, and 6 more sources into a single searchable corpus, then extracts pain-points and workarounds via LLM.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/reddit-cli"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "./Entitlements.plist"
    }
  },
  "plugins": {}
}
