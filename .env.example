# Copy to .env and fill in. Or place at ~/.config/reddit-myind/.env (chmod 600).
#
# AUTH MODEL: OAuth refresh token (no password).
# One-time setup:
#   1. Create a "web app" at https://www.reddit.com/prefs/apps
#      - Name: gapmap
#      - Redirect URI: http://localhost:8080
#   2. Run `gapmap auth login` — opens a browser, writes REDDIT_REFRESH_TOKEN here.

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REFRESH_TOKEN=
REDDIT_USER_AGENT=gapmap/0.1

# Optional — only needed for `gapmap analyze` commands
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Optional — override default data dir (default: ./data)
GAPMAP_DATA_DIR=
