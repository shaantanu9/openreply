# Copy to .env and fill in. Or place at ~/.config/reddit-myind/.env (chmod 600).
#
# AUTH MODEL: OAuth refresh token (no password).
# One-time setup:
#   1. Create a "web app" at https://www.reddit.com/prefs/apps
#      - Name: openreply
#      - Redirect URI: http://localhost:8080
#   2. Run `openreply auth login` — opens a browser, writes REDDIT_REFRESH_TOKEN here.

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REFRESH_TOKEN=
REDDIT_USER_AGENT=openreply/0.1

# Optional — only needed for `openreply analyze` commands
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Optional — override default data dir (default: ./data)
OPENREPLY_DATA_DIR=

# Optional — Product Hunt (competitor sweeps + launch/early-adopter signal).
# Two ways (either works; leave blank to skip Product Hunt):
#   A) Simplest — a Developer Token (no expiry):
#      https://api.producthunt.com/v2/oauth/applications → your app → Developer Token
PH_TOKEN=
#   B) Auto-mint — app credentials (client_credentials grant, auto-refreshes):
PH_CLIENT_ID=
PH_CLIENT_SECRET=
# (You can also paste the Developer Token in-app: Settings → Connections → Product Hunt.)
